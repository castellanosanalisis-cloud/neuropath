# FastAPI Configuration
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neuropath
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neuropath
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","https://yourdomain.com"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# LTI Configuration
LTI_CLIENT_ID=your-lti-client-id
LTI_CLIENT_SECRET=your-lti-client-secret
LTI_ENDPOINT=https://lti-provider.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@neuropath.io

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=neuropath-storage

# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-dsn

# AI Model Configuration
ML_MODEL_PATH=/models/lumi_predictor.pkl
ML_THRESHOLD_COGNITIVE_FATIGUE=0.75
ML_THRESHOLD_ABANDONMENT=0.80

# Application Settings
APP_TITLE=NeuroPath
APP_VERSION=1.0.0
APP_DESCRIPTION=Infraestructura de Accesibilidad Cognitiva